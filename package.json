{
  "name": "chatgpt-long-chat-optimizer",
  "description": "Make long ChatGPT chats load faster and stay responsive by keeping only recent exchanges active.",
  "version": "1.0.4",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "node scripts/build.cjs",
    "build:debug": "node scripts/build.cjs --no-minify",
    "build:chrome": "node scripts/build.cjs --target=chrome",
    "build:chrome:debug": "node scripts/build.cjs --target=chrome --no-minify",
    "build:firefox": "node scripts/build.cjs --target=firefox",
    "build:firefox:debug": "node scripts/build.cjs --target=firefox --no-minify",
    "build:safari": "node scripts/build.cjs --target=safari",
    "build:safari:debug": "node scripts/build.cjs --target=safari --no-minify",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run build:chrome:debug && playwright test",
    "verify": "npm test && npm run build",
    "verify:debug": "npm test && npm run build:debug",
    "verify:full": "npm test && npm run test:e2e && npm run build",
    "verify:full:debug": "npm test && npm run test:e2e && npm run build:debug",
    "package:all": "node scripts/package-release.cjs --target=all",
    "package:chrome": "node scripts/package-release.cjs --target=chrome",
    "package:firefox": "node scripts/package-release.cjs --target=firefox",
    "package:safari": "node scripts/package-release.cjs --target=safari",
    "verify:zip": "node scripts/verify-release-zip.cjs --target=all",
    "verify:zip:chrome": "node scripts/verify-release-zip.cjs --target=chrome",
    "verify:zip:firefox": "node scripts/verify-release-zip.cjs --target=firefox",
    "verify:zip:safari": "node scripts/verify-release-zip.cjs --target=safari",
    "verify:release": "npm run verify && npm run package:all && npm run verify:zip",
    "verify:release:chrome": "npm run verify && npm run package:chrome && npm run verify:zip:chrome",
    "verify:release:full": "npm run verify:full && npm run package:all && npm run verify:zip",
    "export": "node scripts/export-context.cjs",
    "export:src": "node scripts/export-context.cjs src",
    "export:tests": "node scripts/export-context.cjs tests --output testing_context.txt",
    "export:code": "node scripts/export-context.cjs code"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/chrome": "^0.1.39",
    "@types/node": "^25.6.0",
    "adm-zip": "^0.5.17",
    "esbuild": "^0.27.5",
    "http-server": "^14.1.1",
    "jsdom": "^25.0.0",
    "sharp": "^0.34.5",
    "vitest": "^2.1.8"
  },
  "keywords": [
    "chatgpt",
    "browser-extension",
    "performance",
    "productivity"
  ],
  "author": {
    "name": "Antti Ruusunen",
    "url": "https://github.com/anttiruusunen"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/anttiruusunen/chatgpt-long-chat-optimizer"
  },
  "license": "MIT"
}
