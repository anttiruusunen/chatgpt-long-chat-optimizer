{
  "name": "ai_prompt_speed_optimizer",
  "version": "1.0.0",
  "main": "build.js",
  "type": "module",
  "scripts": {
    "build": "node scripts/build.cjs",
    "build:debug": "node scripts/build.cjs --no-minify",
    "build:chrome": "node scripts/build.cjs --target=chrome",
    "build:chrome:debug": "node scripts/build.cjs --target=chrome --no-minify",
    "build:firefox": "node scripts/build.cjs --target=firefox",
    "build:firefox:debug": "node scripts/build.cjs --target=firefox --no-minify",
    "build:safari": "node scripts/build.cjs --target=safari",
    "build:safari:debug": "node scripts/build.cjs --target=safari --no-minify",
    "test": "vitest run",
    "test:e2e": "npm run build:chrome:debug && playwright test",
    "test:watch": "vitest",
    "verify": "npm test && npm run build",
    "verify:debug": "npm test && npm run build:debug",
    "export": "node scripts/export-context.cjs",
    "export:src": "node scripts/export-context.cjs src",
    "export:tests": "node scripts/export-context.cjs tests --output testing_context.txt",
    "export:code": "node scripts/export-context.cjs code"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/chrome": "^0.1.39",
    "@types/node": "^25.6.0",
    "esbuild": "^0.27.5",
    "http-server": "^14.1.1",
    "jsdom": "^25.0.0",
    "vitest": "^2.1.8"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": ""
}