{
  "manifest_version": 3,
  "name": "ChatGPT Thread Optimizer",
  "version": "1.0.0",
  "description": "Keeps long ChatGPT threads responsive by pruning older messages and optimizing heavy code blocks.",
  "permissions": [
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "https://chatgpt.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*"
      ],
      "js": [
        "bridgeBootstrap.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://chatgpt.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "page/chatStorePageBridge.js"
      ],
      "matches": [
        "https://chatgpt.com/*"
      ]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "thread-optimizer@example.com",
      "strict_min_version": "121.0"
    }
  }
}