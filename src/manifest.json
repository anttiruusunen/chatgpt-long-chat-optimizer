{
  "manifest_version": 3,
  "name": "ChatGPT Long Chat Optimizer",
  "short_name": "Long Chat Optimizer",
  "description": "Speed up long ChatGPT conversations by pruning old chat turns and reducing page slowdown.",
  "version": "1.0.0",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://chatgpt.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*"
      ],
      "js": [
        "bridgeBootstrap.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://chatgpt.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "thread-optimizer-for-chatgpt@anttiruusunen",
      "strict_min_version": "121.0"
    }
  }
}